class Base {
  base_method() {
    print "Base.method()";
  }
}

class Parent < Base {
  init() {
    super.base_method();
  }

  parent_method() {
    print "Parent.parent_method";
    super.base_method();
  }
}

class Child < Parent {
  child_method() {
    print "Child.child_method";

    super.parent_method();
  }
}

var parent = Parent();
parent.parent_method();
